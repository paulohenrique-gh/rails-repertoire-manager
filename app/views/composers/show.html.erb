<div class="container w-50">
  <h1 class="text-center mb-5">Detalhes do <%= Composer.model_name.human.downcase %></h1>

  <div class="mb-5">
    <div>
      <strong><%= Composer.human_attribute_name('name') %>: </strong>
      <%= @composer.name.titleize %>
    </div>
    <div>
      <strong><%= Composer.human_attribute_name('period') %>: </strong>
      <%= @composer.period.name %>
    </div>
    <% if @composer.notes.present? %>
      <strong><%= Composer.human_attribute_name('notes') %>: </strong>
      <%= @composer.notes %>
    <% end %>
  </div>

  <div class="text-center mb-5">
    <%= link_to t('helpers.edit'), edit_composer_path(@composer),
                class: 'btn btn-outline-success' %>
  </div>

  <div class="text-center mb-5">
    <%= link_to t('helpers.back'), composers_path %>
  </div>
</div>