<div class="container w-50">
  <h1 class="text-center mb-5">
    Cadastro de <%= Piece.model_name.human.downcase %>
  </h1>

  <div class="text-center mb-5">
    <%= render partial: 'shared/error_messages',
               locals: { resource: @piece } %>
  </div>

  <%= form_with model: @piece do |f| %>
    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :title %>
      </div>
      <div class="col-7">
        <div>
          <%= f.text_field :title, class: 'form-control', required: true %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :opus %>
      </div>
      <div class="col-7">
        <div>
          <%= f.text_field :opus, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :number %>
      </div>
      <div class="col-7">
        <div>
          <%= f.number_field :number, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :movement %>
      </div>
      <div class="col-7">
        <div>
          <%= f.number_field :movement, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :other_identifiers %>
      </div>
      <div class="col-7">
        <div>
          <%= f.text_field :other_identifiers, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :composer_id %>
      </div>
      <div class="col-7">
        <div>
          <%= f.collection_select :composer_id, @composers, :id, :title_name %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :period_id %>
      </div>
      <div class="col-7">
        <div>
          <%= f.collection_select :period_id, @periods, :id, :title_name %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :instrument_id %>
      </div>
      <div class="col-7">
        <div>
          <%= f.collection_select :instrument_id, @instruments, :id, :title_name %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :start_date %>
      </div>
      <div class="col-7">
        <div>
          <%= f.date_field :start_date, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :finish_date %>
      </div>
      <div class="col-7">
        <div>
          <%= f.date_field :finish_date, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-5 col-form-label">
        <%= f.label :difficulty_level %>
      </div>
      <div class="col-7">
        <div>
          <%= f.number_field :difficulty_level, class: 'form-control' %>
        </div>
      </div>
    </div>

    <div class="text-center mb-5">
      <%= f.submit t('helpers.submit.submit'), class: 'btn btn-outline-success' %>
    </div>

    <div class="text-center">
      <%= link_to t('helpers.back'), root_path %>
    </div>
  <% end %>
</div>

